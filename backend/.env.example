PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/dhaneshwari
JWT_SECRET=replace_with_a_strong_secret

# Comma-separated list allows both local and live frontend.
FRONTEND_URLS=http://localhost:5173,https://dhaneshwari-alpha.vercel.app
# Optional fallback used by some routes.
FRONTEND_URL=http://localhost:5173
SITE_URL=https://dhaneshwari-alpha.vercel.app

EMAIL_USER=your_email@example.com
EMAIL_PASS=your_email_app_password
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
